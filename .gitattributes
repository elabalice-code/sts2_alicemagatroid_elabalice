# Normalize EOL for all text files
* text=auto eol=lf
# Git LFS tracking for Godot portable binaries
_godot/*.exe filter=lfs diff=lfs merge=lfs -text
_godot/GodotSharp/** filter=lfs diff=lfs merge=lfs -text
# PNG images tracked via Git LFS (optional — remove if too large)
*.png filter=lfs diff=lfs merge=lfs -text
